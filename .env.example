# Copy this file to `.env` and fill in the keys you want.
# Everything here is ALSO editable live from the /settings panel.

# --- Infra secrets (generate fresh!) ---
AUTH_TOKEN=change-me-openssl-rand-hex-32
POSTGRES_PASSWORD=change-me-openssl-rand-hex-16

# --- LLMs (need at least one for the AI synthesis) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

DEFAULT_LLM=gemini

# --- Optional collectors (all free tiers) ---
GITHUB_TOKEN=                  # https://github.com/settings/tokens (classic, no scopes)
REDDIT_CLIENT_ID=              # https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=osint-tool/1.0
COMPANIES_HOUSE_KEY=
RAPIDAPI_KEY=                  # enables WhatsApp OSINT, Social Media Scanner, MailCheck, PhoneValidate, ReverseImage, GuardDoxx
SHODAN_API_KEY=
URLSCAN_API_KEY=
LEAKIX_API_KEY=
HUNTER_API_KEY=
NUMVERIFY_API_KEY=

# --- Runtime tuning ---
LOGIN_PASSWORD=                # leftover from earlier versions; auth is now free
DEFAULT_TIMEOUT_MINUTES=20
MAX_CONCURRENT_COLLECTORS=40
DEFAULT_LANGUAGE=es
SHERLOCK_TIMEOUT=30
MAIGRET_TIMEOUT=60
PUBLIC_DOMAIN=localhost
