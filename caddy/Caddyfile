{
    email admin@worldmapsound.com
}

who.worldmapsound.com {
    encode gzip zstd

    # SSE needs long timeouts and no buffering
    reverse_proxy backend:8000 {
        flush_interval -1
        transport http {
            read_timeout 30m
            write_timeout 30m
        }
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        X-Frame-Options "DENY"
        -Server
    }
}
